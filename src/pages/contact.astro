---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Chatbot from '../components/Chatbot.astro';
import {
	BLOGGER_URL,
	EMAIL,
	FORBES_URL,
	GITHUB_URL,
	LINKEDIN_URL,
	MEDIUM_URL,
	SITE_TITLE,
	TRAILBLAZER_URL,
	YOUTUBE_URL,
} from '../consts';

const channels: { label: string; value: string; href: string; external: boolean; icon: string }[] = [
	{ label: 'Email',              value: EMAIL,                          href: `mailto:${EMAIL}`, external: false, icon: 'email' },
	{ label: 'LinkedIn',            value: 'in/shikhergoel',              href: LINKEDIN_URL,      external: true,  icon: 'linkedin' },
	{ label: 'YouTube',             value: '@shikhergoel1700',            href: YOUTUBE_URL,       external: true,  icon: 'youtube' },
	{ label: 'Medium',              value: '@shikher20goel',              href: MEDIUM_URL,        external: true,  icon: 'medium' },
	{ label: 'Forbes Tech Council', value: 'forbes.com/…/shikhergoel',    href: FORBES_URL,        external: true,  icon: 'forbes' },
	{ label: 'Trailblazer',         value: 'trailblazer/sgoel2',          href: TRAILBLAZER_URL,   external: true,  icon: 'trailblazer' },
	{ label: 'GitHub',              value: 'github.com/shikher20goel',    href: GITHUB_URL,        external: true,  icon: 'github' },
	{ label: 'Blogger',             value: 'shikhergoel.blogspot.com',    href: BLOGGER_URL,       external: true,  icon: 'blogger' },
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Contact | ${SITE_TITLE}`} description="Get in touch with Shikher Goel — email, LinkedIn, YouTube, Medium, Forbes, GitHub." />
		<style>
			main.contact-page { width: 100%; max-width: 760px; margin: 0 auto; padding: 3em 1.5em; }

			.head { margin-bottom: 2em; }
			.head h1 {
				font-size: clamp(2em, 4.5vw, 2.6em);
				margin: 0 0 0.3em;
				letter-spacing: -0.02em;
			}
			.head p {
				color: rgb(var(--gray));
				margin: 0;
				font-size: 1.05em;
			}

			.channels {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
				gap: 0.8em;
				margin-top: 1.5em;
			}
			.channel {
				display: flex;
				align-items: center;
				gap: 0.9em;
				padding: 1em 1.2em;
				background: white;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 12px;
				text-decoration: none;
				color: inherit;
				transition: all 0.2s ease;
			}
			.channel:hover {
				border-color: var(--accent);
				transform: translateY(-2px);
				box-shadow: 0 6px 18px -6px rgba(35, 55, 255, 0.15);
			}
			.channel .icon {
				width: 36px;
				height: 36px;
				flex-shrink: 0;
				border-radius: 8px;
				display: flex;
				align-items: center;
				justify-content: center;
				color: white;
				font-weight: 800;
				font-size: 0.85em;
			}
			.channel .label {
				font-size: 0.72em;
				color: rgb(var(--gray));
				text-transform: uppercase;
				letter-spacing: 1.5px;
				font-weight: 600;
				margin: 0 0 0.15em;
			}
			.channel .value {
				font-size: 0.95em;
				font-weight: 600;
				color: rgb(var(--black));
				margin: 0;
				word-break: break-all;
			}

			/* Per-channel brand colors */
			.icon.email      { background: linear-gradient(135deg, #2337ff, #9b5cff); }
			.icon.linkedin   { background: #0A66C2; }
			.icon.youtube    { background: #FF0000; }
			.icon.medium     { background: #00AB6C; }
			.icon.forbes     { background: #D00000; }
			.icon.trailblazer { background: #00A1E0; }
			.icon.github     { background: #181717; }
			.icon.blogger    { background: #FF5722; }
		</style>
	</head>
	<body>
		<Header />
		<main class="contact-page">
			<div class="head">
				<h1>Contact</h1>
				<p>The fastest way to reach me is email. I'm also active on LinkedIn and happy to chat about enterprise architecture, AI, Salesforce, or your project idea.</p>
			</div>

			<div class="channels">
				{channels.map((c) => (
					<a class="channel" href={c.href} target={c.external ? '_blank' : undefined} rel={c.external ? 'noopener noreferrer' : undefined}>
						<div class={`icon ${c.icon}`}>
							{c.icon === 'email' && <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>}
							{c.icon === 'linkedin' && <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.063 2.063 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>}
							{c.icon === 'youtube' && <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>}
							{c.icon === 'medium' && <span>M</span>}
							{c.icon === 'forbes' && <span>F</span>}
							{c.icon === 'trailblazer' && <span>T</span>}
							{c.icon === 'github' && <svg width="18" height="18" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>}
							{c.icon === 'blogger' && <span>B</span>}
						</div>
						<div>
							<p class="label">{c.label}</p>
							<p class="value">{c.value}</p>
						</div>
					</a>
				))}
			</div>
		</main>
		<Footer />
		<Chatbot />
	</body>
</html>
