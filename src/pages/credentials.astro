---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Chatbot from '../components/Chatbot.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { MEMBERSHIPS, SITE_TITLE, TRAILBLAZER_URL } from '../consts';

const certsRaw = await getCollection('certifications').catch(() => []);

const sfCerts = certsRaw
	.filter((c) => c.data.issuer === 'Salesforce')
	.sort((a, b) => (b.data.dateEarned?.valueOf() ?? 0) - (a.data.dateEarned?.valueOf() ?? 0));
const awsCerts = certsRaw
	.filter((c) => c.data.issuer === 'AWS')
	.sort((a, b) => (b.data.dateEarned?.valueOf() ?? 0) - (a.data.dateEarned?.valueOf() ?? 0));
const otherCerts = certsRaw
	.filter((c) => c.data.issuer === 'Other')
	.sort((a, b) => (b.data.dateEarned?.valueOf() ?? 0) - (a.data.dateEarned?.valueOf() ?? 0));
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Credentials | ${SITE_TITLE}`}
			description="Salesforce and AWS certifications, professional memberships, and fellowships."
		/>
		<style>
			main.credentials-page { width: 100%; max-width: 1020px; margin: 0 auto; padding: 3em 1.5em; }

			.head { text-align: center; margin-bottom: 3em; }
			.head h1 {
				font-size: clamp(2em, 4.5vw, 2.8em);
				margin: 0 0 0.3em;
				letter-spacing: -0.02em;
			}
			.head p {
				color: rgb(var(--gray));
				margin: 0;
				font-size: 1.05em;
			}

			.section { margin-bottom: 3.5em; }
			.section-head {
				display: flex;
				align-items: baseline;
				gap: 0.8em;
				margin-bottom: 1.5em;
				padding-bottom: 0.8em;
				border-bottom: 2px solid rgb(var(--gray-light));
			}
			.section-head h2 {
				margin: 0;
				font-size: 1.5em;
				font-weight: 700;
				letter-spacing: -0.01em;
			}
			.section-head .count {
				color: rgb(var(--gray));
				font-size: 0.95em;
			}
			.section-head .verify {
				margin-left: auto;
				font-size: 0.85em;
				color: var(--accent);
			}

			.cert-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
				gap: 0.8em;
			}
			.cert {
				display: block;
				padding: 1em 1.1em;
				background: white;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 10px;
				text-decoration: none;
				color: inherit;
				transition: all 0.2s ease;
				position: relative;
			}
			.cert.linked:hover {
				border-color: var(--accent);
				transform: translateY(-2px);
				box-shadow: 0 6px 18px -6px rgba(35, 55, 255, 0.15);
			}
			.cert h3 {
				margin: 0 0 0.3em;
				font-size: 0.95em;
				line-height: 1.35;
				font-weight: 600;
				color: rgb(var(--black));
			}
			.cert .date {
				font-size: 0.78em;
				color: rgb(var(--gray));
			}
			.cert .badge-strip {
				position: absolute;
				left: 0;
				top: 0;
				bottom: 0;
				width: 3px;
				border-radius: 10px 0 0 10px;
			}
			.cert.Salesforce .badge-strip { background: #00A1E0; }
			.cert.AWS .badge-strip { background: #FF9900; }
			.cert.Other .badge-strip { background: #6c8cff; }

			.memberships {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
				gap: 1em;
			}
			.membership {
				padding: 1.2em 1.3em;
				background: white;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 12px;
				text-decoration: none;
				color: inherit;
				display: block;
				transition: all 0.2s ease;
			}
			.membership:hover {
				border-color: var(--accent);
				transform: translateY(-2px);
			}
			.membership .org {
				font-size: 0.78em;
				color: rgb(var(--gray));
				text-transform: uppercase;
				letter-spacing: 1.5px;
				font-weight: 600;
				margin-bottom: 0.2em;
			}
			.membership .role {
				font-size: 1.1em;
				font-weight: 600;
				color: rgb(var(--black));
				margin: 0;
			}

			.empty {
				padding: 2em;
				text-align: center;
				background: rgb(var(--gray-light));
				border-radius: 12px;
				color: rgb(var(--gray-dark));
				font-style: italic;
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="credentials-page">
			<div class="head">
				<h1>Credentials</h1>
				<p>Certifications, memberships, and fellowships.</p>
			</div>

			<!-- Salesforce Certifications -->
			<section class="section">
				<div class="section-head">
					<h2>Salesforce</h2>
					<span class="count">{sfCerts.length > 0 ? `${sfCerts.length} certifications` : '19× Salesforce Certified'}</span>
					<a class="verify" href={TRAILBLAZER_URL} target="_blank" rel="noopener noreferrer">Verify on Trailblazer →</a>
				</div>
				{sfCerts.length === 0 ? (
					<div class="empty">
						Verified on the <a href={TRAILBLAZER_URL} target="_blank" rel="noopener noreferrer">Trailblazer profile</a>. Full list coming here soon — drop <code>.md</code> files into <code>src/content/certifications/</code>.
					</div>
				) : (
					<div class="cert-grid">
						{sfCerts.map((c) => {
							const Tag = c.data.credentialUrl ? 'a' : 'div';
							return (
								<Tag
									class={`cert Salesforce ${c.data.credentialUrl ? 'linked' : ''}`}
									href={c.data.credentialUrl}
									target={c.data.credentialUrl ? '_blank' : undefined}
									rel={c.data.credentialUrl ? 'noopener noreferrer' : undefined}
								>
									<span class="badge-strip"></span>
									<h3>{c.data.title}</h3>
									{c.data.dateEarned && (
										<span class="date"><FormattedDate date={c.data.dateEarned} /></span>
									)}
								</Tag>
							);
						})}
					</div>
				)}
			</section>

			<!-- AWS Certifications -->
			<section class="section">
				<div class="section-head">
					<h2>AWS</h2>
					<span class="count">{awsCerts.length > 0 ? `${awsCerts.length} certifications` : '2× AWS Certified'}</span>
				</div>
				{awsCerts.length === 0 ? (
					<div class="empty">
						AWS certification list will populate when <code>.md</code> files are added to <code>src/content/certifications/</code>.
					</div>
				) : (
					<div class="cert-grid">
						{awsCerts.map((c) => {
							const Tag = c.data.credentialUrl ? 'a' : 'div';
							return (
								<Tag
									class={`cert AWS ${c.data.credentialUrl ? 'linked' : ''}`}
									href={c.data.credentialUrl}
									target={c.data.credentialUrl ? '_blank' : undefined}
									rel={c.data.credentialUrl ? 'noopener noreferrer' : undefined}
								>
									<span class="badge-strip"></span>
									<h3>{c.data.title}</h3>
									{c.data.dateEarned && (
										<span class="date"><FormattedDate date={c.data.dateEarned} /></span>
									)}
								</Tag>
							);
						})}
					</div>
				)}
			</section>

			<!-- Other Certifications -->
			{otherCerts.length > 0 && (
				<section class="section">
					<div class="section-head">
						<h2>Other</h2>
						<span class="count">{otherCerts.length} certifications</span>
					</div>
					<div class="cert-grid">
						{otherCerts.map((c) => {
							const Tag = c.data.credentialUrl ? 'a' : 'div';
							return (
								<Tag
									class={`cert Other ${c.data.credentialUrl ? 'linked' : ''}`}
									href={c.data.credentialUrl}
									target={c.data.credentialUrl ? '_blank' : undefined}
									rel={c.data.credentialUrl ? 'noopener noreferrer' : undefined}
								>
									<span class="badge-strip"></span>
									<h3>{c.data.title}</h3>
									{c.data.dateEarned && (
										<span class="date"><FormattedDate date={c.data.dateEarned} /></span>
									)}
								</Tag>
							);
						})}
					</div>
				</section>
			)}

			<!-- Memberships -->
			<section class="section">
				<div class="section-head">
					<h2>Memberships & Fellowships</h2>
					<span class="count">{MEMBERSHIPS.length}</span>
				</div>
				<div class="memberships">
					{MEMBERSHIPS.map((m) => {
						const Tag = m.url ? 'a' : 'div';
						return (
							<Tag
								class="membership"
								href={m.url}
								target={m.url ? '_blank' : undefined}
								rel={m.url ? 'noopener noreferrer' : undefined}
							>
								<p class="org">{m.org}</p>
								<p class="role">{m.role}</p>
							</Tag>
						);
					})}
				</div>
			</section>
		</main>
		<Footer />
		<Chatbot />
	</body>
</html>
