---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Chatbot from '../components/Chatbot.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE } from '../consts';

// Pull all three collections. Any that errors returns [] so the page still renders.
const [ownPosts, forbesPosts, externalPosts] = await Promise.all([
	getCollection('blog').catch(() => []),
	getCollection('forbes').catch(() => []),
	getCollection('external').catch(() => []),
]);

type Card = {
	id: string;
	title: string;
	pubDate: Date;
	href: string;
	external: boolean;
	excerpt: string;
	source: 'own' | 'medium' | 'blogger' | 'forbes';
	sourceLabel: string;
};

const cards: Card[] = [
	...ownPosts.map((p): Card => ({
		id: `own-${p.id}`,
		title: p.data.title,
		pubDate: p.data.pubDate,
		href: `/blog/${p.id}/`,
		external: false,
		excerpt: p.data.description,
		source: 'own',
		sourceLabel: 'On this site',
	})),
	...forbesPosts.map((p): Card => ({
		id: `forbes-${p.id}`,
		title: p.data.title,
		pubDate: p.data.pubDate,
		href: p.data.url,
		external: true,
		excerpt: p.data.excerpt,
		source: 'forbes',
		sourceLabel: 'Forbes',
	})),
	...externalPosts.map((p): Card => ({
		id: `ext-${p.id}`,
		title: p.data.title,
		pubDate: p.data.pubDate,
		href: p.data.url,
		external: true,
		excerpt: p.data.excerpt,
		source: p.data.source,
		sourceLabel: p.data.source === 'medium' ? 'Medium' : 'Blogger',
	})),
].sort((a, b) => b.pubDate.valueOf() - a.pubDate.valueOf());

const counts = {
	total: cards.length,
	medium: cards.filter((c) => c.source === 'medium').length,
	blogger: cards.filter((c) => c.source === 'blogger').length,
	forbes: cards.filter((c) => c.source === 'forbes').length,
	own: cards.filter((c) => c.source === 'own').length,
};
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Writing | ${SITE_TITLE}`}
			description="All of Shikher Goel's writing across Medium, Blogger, Forbes, and this site."
		/>
		<style>
			.wrap { max-width: 820px; margin: 0 auto; padding: 2em 1em; }
			.intro { color: rgb(var(--gray)); margin-bottom: 2em; }
			.counts { font-size: 0.85em; color: rgb(var(--gray)); margin-top: 0.3em; }

			.post {
				border-bottom: 1px solid rgb(var(--gray-light));
				padding: 1.5em 0;
			}
			.post:first-of-type { padding-top: 0.5em; }
			.post:last-of-type { border-bottom: none; }

			.meta {
				display: flex;
				align-items: center;
				gap: 0.6em;
				font-size: 0.8em;
				color: rgb(var(--gray));
				margin-bottom: 0.4em;
				text-transform: uppercase;
				letter-spacing: 0.5px;
			}
			.badge {
				display: inline-block;
				padding: 0.15em 0.6em;
				border-radius: 999px;
				font-size: 0.75em;
				font-weight: 600;
				letter-spacing: 0.5px;
			}
			.badge.medium { background: #00ab6c1a; color: #00ab6c; }
			.badge.blogger { background: #ff57221a; color: #ff5722; }
			.badge.forbes { background: #d000001a; color: #d00000; }
			.badge.own { background: rgb(var(--gray-light)); color: rgb(var(--gray-dark)); }

			.post h2 {
				margin: 0 0 0.4em;
				font-size: 1.3em;
				line-height: 1.3;
			}
			.post h2 a { color: inherit; text-decoration: none; }
			.post h2 a:hover { color: var(--accent); }

			.excerpt {
				margin: 0 0 0.6em;
				color: rgb(var(--gray-dark));
				line-height: 1.55;
			}

			.cta {
				font-size: 0.9em;
				font-weight: 500;
			}
			.external-icon {
				display: inline-block;
				vertical-align: baseline;
				margin-left: 0.2em;
				opacity: 0.7;
			}

			.empty {
				padding: 3em 0;
				text-align: center;
				color: rgb(var(--gray));
				font-style: italic;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="wrap">
				<h1>Writing</h1>
				<p class="intro">
					Everything I've written — on Medium, Blogger, Forbes, and here. Automatically kept in sync daily.
				</p>
				<p class="counts">
					{counts.total} posts · {counts.medium} Medium · {counts.blogger} Blogger · {counts.forbes} Forbes · {counts.own} here
				</p>

				{cards.length === 0 ? (
					<p class="empty">No posts yet — feeds will populate on the next build.</p>
				) : (
					<div>
						{cards.map((c) => (
							<article class="post">
								<div class="meta">
									<span class={`badge ${c.source}`}>{c.sourceLabel}</span>
									<span><FormattedDate date={c.pubDate} /></span>
								</div>
								<h2>
									{c.external ? (
										<a href={c.href} target="_blank" rel="noopener noreferrer">{c.title}</a>
									) : (
										<a href={c.href}>{c.title}</a>
									)}
								</h2>
								<p class="excerpt">{c.excerpt}</p>
								<p class="cta">
									{c.external ? (
										<a href={c.href} target="_blank" rel="noopener noreferrer">
											Continue reading on {c.sourceLabel}
											<svg class="external-icon" viewBox="0 0 24 24" width="12" height="12" aria-hidden="true">
												<path fill="currentColor" d="M14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7zM19 19H5V5h7V3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2v-7h-2v7z"/>
											</svg>
										</a>
									) : (
										<a href={c.href}>Read &rsaquo;</a>
									)}
								</p>
							</article>
						))}
					</div>
				)}
			</div>
		</main>
		<Footer />
		<Chatbot />
	</body>
</html>
