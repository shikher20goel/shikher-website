---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Chatbot from '../components/Chatbot.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE, YOUTUBE_URL } from '../consts';

const videosRaw = await getCollection('videos').catch(() => []);
const videos = videosRaw.sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Videos | ${SITE_TITLE}`}
			description="YouTube videos by Shikher Goel on AI, enterprise architecture, and Salesforce."
		/>
		<style>
			main.videos-page { width: 100%; max-width: 1180px; margin: 0 auto; padding: 3em 1.5em; }

			.head { text-align: center; margin-bottom: 3em; }
			.head h1 {
				font-size: clamp(2em, 4.5vw, 2.8em);
				margin: 0 0 0.3em;
				letter-spacing: -0.02em;
			}
			.head p {
				color: rgb(var(--gray));
				margin: 0 0 1.5em;
				font-size: 1.05em;
			}
			.yt-cta {
				display: inline-flex;
				align-items: center;
				gap: 0.5em;
				padding: 0.55em 1.2em;
				background: #FF0000;
				color: white;
				border-radius: 999px;
				text-decoration: none;
				font-size: 0.9em;
				font-weight: 600;
				transition: transform 0.2s ease, box-shadow 0.2s ease;
			}
			.yt-cta:hover {
				transform: translateY(-2px);
				color: white;
				box-shadow: 0 6px 18px rgba(255, 0, 0, 0.25);
			}

			.grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
				gap: 1.5em;
			}
			.video {
				display: block;
				text-decoration: none;
				color: inherit;
				background: white;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 14px;
				overflow: hidden;
				transition:
					transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1),
					box-shadow 0.25s ease,
					border-color 0.25s ease;
			}
			.video:hover {
				transform: translateY(-4px);
				border-color: var(--accent);
				box-shadow: 0 12px 32px -8px rgba(35, 55, 255, 0.2);
			}
			.thumb-wrap {
				position: relative;
				aspect-ratio: 16 / 9;
				background: #000;
				overflow: hidden;
			}
			.thumb-wrap img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				border-radius: 0;
				transition: transform 0.4s ease;
			}
			.video:hover .thumb-wrap img { transform: scale(1.04); }
			.play-overlay {
				position: absolute;
				inset: 0;
				display: flex;
				align-items: center;
				justify-content: center;
				background: rgba(0, 0, 0, 0);
				transition: background 0.2s ease;
			}
			.video:hover .play-overlay { background: rgba(0, 0, 0, 0.25); }
			.play-btn {
				width: 56px;
				height: 56px;
				border-radius: 50%;
				background: rgba(255, 0, 0, 0.95);
				display: flex;
				align-items: center;
				justify-content: center;
				opacity: 0;
				transform: scale(0.85);
				transition: all 0.25s ease;
			}
			.video:hover .play-btn {
				opacity: 1;
				transform: scale(1);
			}
			.play-btn svg { color: white; }

			.body { padding: 1.1em 1.2em 1.3em; }
			.video .meta {
				font-size: 0.73em;
				color: rgb(var(--gray));
				text-transform: uppercase;
				letter-spacing: 1.5px;
				margin-bottom: 0.4em;
				font-weight: 600;
			}
			.video h3 {
				margin: 0 0 0.4em;
				font-size: 1.05em;
				line-height: 1.35;
				font-weight: 700;
				letter-spacing: -0.01em;
				color: rgb(var(--black));
				display: -webkit-box;
				-webkit-line-clamp: 2;
				line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
			.video p.desc {
				margin: 0;
				color: rgb(var(--gray-dark));
				font-size: 0.88em;
				line-height: 1.5;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}

			.empty {
				text-align: center;
				padding: 4em 1em;
				color: rgb(var(--gray));
				background: rgb(var(--gray-light));
				border-radius: 14px;
			}
			.empty strong { display: block; margin-bottom: 0.4em; color: rgb(var(--gray-dark)); }
		</style>
	</head>
	<body>
		<Header />
		<main class="videos-page">
			<div class="head">
				<h1>Videos</h1>
				<p>Talks, walkthroughs, and explainers on AI, enterprise architecture, and Salesforce.</p>
				<a class="yt-cta" href={YOUTUBE_URL} target="_blank" rel="noopener noreferrer">
					<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
						<path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" />
					</svg>
					Subscribe on YouTube
				</a>
			</div>

			{videos.length === 0 ? (
				<div class="empty">
					<strong>Videos feed not yet connected.</strong>
					Add your YouTube Channel ID to <code>src/consts.ts</code> (see file comments) and redeploy — videos will appear here automatically.
				</div>
			) : (
				<div class="grid">
					{videos.map((v) => (
						<a class="video" href={v.data.url} target="_blank" rel="noopener noreferrer">
							<div class="thumb-wrap">
								<img src={v.data.thumbnail} alt={v.data.title} loading="lazy" />
								<div class="play-overlay">
									<div class="play-btn">
										<svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
											<path d="M8 5v14l11-7z" />
										</svg>
									</div>
								</div>
							</div>
							<div class="body">
								<p class="meta"><FormattedDate date={v.data.pubDate} /></p>
								<h3>{v.data.title}</h3>
								{v.data.description && <p class="desc">{v.data.description}</p>}
							</div>
						</a>
					))}
				</div>
			)}
		</main>
		<Footer />
		<Chatbot />
	</body>
</html>
