---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Chatbot from '../components/Chatbot.astro';
import FormattedDate from '../components/FormattedDate.astro';
import {
	BLOGGER_URL,
	EMAIL,
	FORBES_URL,
	GITHUB_URL,
	LINKEDIN_URL,
	MEDIUM_URL,
	SITE_DESCRIPTION,
	SITE_TITLE,
	TRAILBLAZER_URL,
	YOUTUBE_URL,
} from '../consts';

const [externalRaw, forbesRaw, videosRaw] = await Promise.all([
	getCollection('external').catch(() => []),
	getCollection('forbes').catch(() => []),
	getCollection('videos').catch(() => []),
]);

const mediumPosts = externalRaw
	.filter((p) => p.data.source === 'medium')
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 2);

const forbesPosts = forbesRaw
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 2);

const topVideos = videosRaw
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);

const totalPosts = externalRaw.length + forbesRaw.length;

// JSON-LD Person schema for Google rich results.
const personSchema = {
	'@context': 'https://schema.org',
	'@type': 'Person',
	name: 'Shikher Goel',
	url: Astro.site?.toString() ?? 'https://shikhergoel.com',
	jobTitle: 'Enterprise Architect',
	description:
		'Enterprise architect, AI practitioner, and writer. Forbes Tech Council member. 19× Salesforce Certified. 2× AWS Certified. IEEE Senior Member.',
	email: `mailto:${EMAIL}`,
	sameAs: [
		LINKEDIN_URL,
		YOUTUBE_URL,
		MEDIUM_URL,
		FORBES_URL,
		TRAILBLAZER_URL,
		GITHUB_URL,
		BLOGGER_URL,
	],
	memberOf: [
		{ '@type': 'Organization', name: 'Forbes Technology Council', url: FORBES_URL },
		{ '@type': 'Organization', name: 'IEEE' },
		{ '@type': 'Organization', name: 'Hackathon Raptors' },
		{ '@type': 'Organization', name: 'IOSAD' },
	],
	knowsAbout: [
		'Salesforce',
		'AWS',
		'Enterprise Architecture',
		'Artificial Intelligence',
		'Large Language Models',
		'Prompt Engineering',
		'System Design',
	],
};

const credentials = [
	'Forbes Tech Council',
	'19× Salesforce Certified',
	'2× AWS Certified',
	'IEEE Senior Member',
	'Salesforce CTA Candidate',
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
		<style>
			/* Home overrides the 720px <main> constraint from global.css */
			main.home {
				width: 100%;
				max-width: none;
				padding: 0;
				margin: 0;
			}

			/* ========================================================
			   HERO
			   ======================================================== */
			.hero {
				position: relative;
				padding: 6em 1.5em 5em;
				text-align: center;
				overflow: hidden;
				isolation: isolate;
				background:
					radial-gradient(ellipse 80% 50% at 50% 0%, rgba(35, 55, 255, 0.08), transparent 60%),
					linear-gradient(180deg, #fff 0%, rgba(var(--gray-light), 0.4) 100%);
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			/* Glow orbs (pure CSS, no JS) */
			.hero::before,
			.hero::after {
				content: '';
				position: absolute;
				border-radius: 50%;
				filter: blur(60px);
				opacity: 0.5;
				z-index: -1;
				animation: float 12s ease-in-out infinite;
				pointer-events: none;
			}
			.hero::before {
				top: -100px;
				right: -80px;
				width: 380px;
				height: 380px;
				background: radial-gradient(circle, rgba(155, 92, 255, 0.35), transparent 70%);
			}
			.hero::after {
				bottom: -150px;
				left: -100px;
				width: 420px;
				height: 420px;
				background: radial-gradient(circle, rgba(35, 55, 255, 0.3), transparent 70%);
				animation-delay: -6s;
			}
			@keyframes float {
				0%, 100% { transform: translate(0, 0) scale(1); }
				50% { transform: translate(20px, -20px) scale(1.05); }
			}

			.hero-inner {
				position: relative;
				max-width: 820px;
				margin: 0 auto;
				animation: fade-up 0.8s ease-out both;
			}
			@keyframes fade-up {
				from { opacity: 0; transform: translateY(12px); }
				to { opacity: 1; transform: translateY(0); }
			}

			.eyebrow {
				display: inline-block;
				color: rgb(var(--gray));
				letter-spacing: 3px;
				text-transform: uppercase;
				font-size: 0.75em;
				margin: 0 0 1.2em;
				font-weight: 600;
				padding: 0.35em 1em;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 999px;
				background: rgba(255, 255, 255, 0.6);
				backdrop-filter: blur(10px);
			}

			.hero h1 {
				font-size: clamp(2.5em, 7vw, 4.5em);
				line-height: 1.02;
				margin: 0 0 0.3em;
				letter-spacing: -0.03em;
				font-weight: 800;
				background: linear-gradient(135deg, #2337ff 0%, #9b5cff 50%, #2337ff 100%);
				background-size: 200% auto;
				-webkit-background-clip: text;
				background-clip: text;
				color: transparent;
				animation: gradient-shift 8s linear infinite;
			}
			@keyframes gradient-shift {
				to { background-position: 200% center; }
			}

			.tagline {
				color: rgb(var(--gray-dark));
				font-size: clamp(1.1em, 2.2vw, 1.4em);
				margin: 0 0 1.5em;
				font-weight: 500;
			}

			.credentials {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5em;
				justify-content: center;
				margin: 0 auto 2em;
				max-width: 720px;
			}
			.credential {
				display: inline-flex;
				align-items: center;
				gap: 0.4em;
				background: rgba(255, 255, 255, 0.7);
				border: 1px solid rgb(var(--gray-light));
				color: rgb(var(--gray-dark));
				padding: 0.4em 0.95em;
				border-radius: 999px;
				font-size: 0.82em;
				font-weight: 500;
				backdrop-filter: blur(10px);
				transition: all 0.2s ease;
			}
			.credential:hover {
				border-color: var(--accent);
				transform: translateY(-1px);
			}
			.credential svg { opacity: 0.7; }

			.cta {
				display: flex;
				gap: 0.75em;
				justify-content: center;
				flex-wrap: wrap;
			}
			.btn {
				display: inline-flex;
				align-items: center;
				gap: 0.5em;
				padding: 0.8em 1.6em;
				border-radius: 10px;
				text-decoration: none;
				font-weight: 600;
				font-size: 0.95em;
				transition: all 0.2s ease;
				border: 1px solid transparent;
				cursor: pointer;
			}
			.btn-primary {
				background: linear-gradient(135deg, #2337ff, #9b5cff);
				color: white;
				box-shadow:
					0 4px 14px rgba(35, 55, 255, 0.25),
					0 0 0 1px rgba(35, 55, 255, 0.1);
			}
			.btn-primary:hover {
				transform: translateY(-2px);
				box-shadow:
					0 8px 28px rgba(35, 55, 255, 0.35),
					0 0 0 1px rgba(35, 55, 255, 0.2);
				color: white;
			}
			.btn-ghost {
				background: rgba(255, 255, 255, 0.6);
				color: rgb(var(--gray-dark));
				border-color: rgb(var(--gray-light));
				backdrop-filter: blur(10px);
			}
			.btn-ghost:hover {
				border-color: var(--accent);
				color: var(--accent);
				transform: translateY(-2px);
			}

			/* ========================================================
			   FEATURED WRITING
			   ======================================================== */
			.featured {
				max-width: 1180px;
				margin: 0 auto;
				padding: 5em 1.5em 3em;
			}
			.featured-head {
				text-align: center;
				margin-bottom: 3em;
			}
			.featured-head h2 {
				font-size: clamp(1.8em, 4vw, 2.4em);
				margin: 0 0 0.4em;
				letter-spacing: -0.02em;
			}
			.featured-head p {
				color: rgb(var(--gray));
				font-size: 1.05em;
				margin: 0;
			}

			.columns {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 2em;
			}
			@media (max-width: 860px) {
				.columns { grid-template-columns: 1fr; gap: 3em; }
			}

			.column-head {
				display: flex;
				align-items: center;
				gap: 0.7em;
				margin-bottom: 1.2em;
				padding-bottom: 0.9em;
				border-bottom: 2px solid rgb(var(--gray-light));
			}
			.platform-badge {
				width: 32px;
				height: 32px;
				display: flex;
				align-items: center;
				justify-content: center;
				border-radius: 8px;
				font-weight: 800;
				font-size: 0.9em;
				color: white;
				letter-spacing: -0.03em;
				box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
			}
			.platform-badge.medium { background: #00ab6c; }
			.platform-badge.forbes { background: #d00000; }
			.column-head h3 {
				margin: 0;
				font-size: 1.1em;
				font-weight: 700;
				letter-spacing: -0.01em;
			}
			.column-head .count {
				margin-left: auto;
				color: rgb(var(--gray));
				font-size: 0.85em;
				font-weight: 500;
			}

			.feature-card {
				display: block;
				position: relative;
				padding: 1.6em;
				margin-bottom: 1em;
				background: white;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 14px;
				text-decoration: none;
				color: inherit;
				overflow: hidden;
				transition:
					transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1),
					box-shadow 0.25s ease,
					border-color 0.25s ease;
				isolation: isolate;
			}
			/* shimmer gradient overlay on hover */
			.feature-card::before {
				content: '';
				position: absolute;
				inset: 0;
				background: linear-gradient(135deg, transparent 50%, rgba(35, 55, 255, 0.06));
				opacity: 0;
				transition: opacity 0.3s ease;
				z-index: -1;
				pointer-events: none;
			}
			.feature-card:hover {
				transform: translateY(-4px);
				border-color: var(--accent);
				box-shadow:
					0 12px 32px -8px rgba(35, 55, 255, 0.2),
					0 4px 12px -4px rgba(0, 0, 0, 0.05);
			}
			.feature-card:hover::before { opacity: 1; }

			.card-meta {
				font-size: 0.72em;
				color: rgb(var(--gray));
				text-transform: uppercase;
				letter-spacing: 1.5px;
				margin: 0 0 0.5em;
				font-weight: 600;
			}
			.feature-card h4 {
				margin: 0 0 0.6em;
				font-size: 1.18em;
				line-height: 1.35;
				font-weight: 700;
				letter-spacing: -0.01em;
				color: rgb(var(--black));
				/* leave room for the arrow icon */
				padding-right: 2em;
			}
			.feature-card p.excerpt {
				margin: 0;
				color: rgb(var(--gray-dark));
				font-size: 0.93em;
				line-height: 1.55;
				display: -webkit-box;
				-webkit-line-clamp: 3;
				line-clamp: 3;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
			.card-arrow {
				position: absolute;
				top: 1.6em;
				right: 1.6em;
				opacity: 0;
				transform: translate(-4px, 4px);
				transition: all 0.25s ease;
				color: var(--accent);
			}
			.feature-card:hover .card-arrow {
				opacity: 1;
				transform: translate(0, 0);
			}

			.see-all {
				text-align: center;
				margin-top: 3em;
			}
			.see-all a {
				display: inline-flex;
				align-items: center;
				gap: 0.4em;
				color: var(--accent);
				font-weight: 600;
				font-size: 1em;
				padding: 0.5em 1em;
				border-radius: 8px;
				transition: all 0.2s ease;
			}
			.see-all a:hover {
				background: rgba(35, 55, 255, 0.08);
				gap: 0.6em;
			}

			/* ========================================================
			   VIDEOS SECTION
			   ======================================================== */
			.videos-section {
				max-width: 1180px;
				margin: 1em auto 0;
				padding: 3em 1.5em 1em;
			}
			.videos-head {
				display: flex;
				align-items: baseline;
				gap: 0.8em;
				margin-bottom: 1.5em;
				padding-bottom: 0.8em;
				border-bottom: 2px solid rgb(var(--gray-light));
			}
			.videos-head h2 {
				margin: 0;
				font-size: 1.4em;
				font-weight: 700;
				letter-spacing: -0.01em;
				display: inline-flex;
				align-items: center;
				gap: 0.55em;
			}
			.videos-head h2 .yt-dot {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				width: 28px;
				height: 28px;
				background: #FF0000;
				border-radius: 7px;
				color: white;
			}
			.videos-head .count { color: rgb(var(--gray)); font-size: 0.9em; }
			.videos-head .channel-link {
				margin-left: auto;
				font-size: 0.85em;
				color: var(--accent);
				font-weight: 500;
			}

			.video-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
				gap: 1.2em;
			}
			.video-card {
				display: block;
				text-decoration: none;
				color: inherit;
				background: white;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 14px;
				overflow: hidden;
				transition:
					transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1),
					box-shadow 0.25s ease,
					border-color 0.25s ease;
			}
			.video-card:hover {
				transform: translateY(-4px);
				border-color: var(--accent);
				box-shadow: 0 12px 32px -8px rgba(35, 55, 255, 0.2);
			}
			.video-thumb {
				position: relative;
				aspect-ratio: 16 / 9;
				background: linear-gradient(135deg, #1a1a1a, #000);
				overflow: hidden;
			}
			.video-thumb img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				border-radius: 0;
				transition: transform 0.4s ease;
			}
			.video-card:hover .video-thumb img { transform: scale(1.05); }
			.video-thumb::after {
				content: '';
				position: absolute;
				inset: 0;
				background: radial-gradient(circle at center, transparent 30%, rgba(0,0,0,0.35) 100%);
				opacity: 0;
				transition: opacity 0.25s ease;
			}
			.video-card:hover .video-thumb::after { opacity: 1; }
			.video-play {
				position: absolute;
				top: 50%;
				left: 50%;
				transform: translate(-50%, -50%) scale(0.85);
				width: 56px;
				height: 56px;
				border-radius: 50%;
				background: rgba(255, 0, 0, 0.95);
				display: flex;
				align-items: center;
				justify-content: center;
				opacity: 0;
				transition: all 0.25s ease;
				z-index: 1;
			}
			.video-card:hover .video-play {
				opacity: 1;
				transform: translate(-50%, -50%) scale(1);
			}
			.video-body { padding: 1em 1.2em 1.2em; }
			.video-body .meta {
				font-size: 0.72em;
				color: rgb(var(--gray));
				text-transform: uppercase;
				letter-spacing: 1.3px;
				margin-bottom: 0.4em;
				font-weight: 600;
			}
			.video-body h3 {
				margin: 0;
				font-size: 1em;
				line-height: 1.35;
				font-weight: 700;
				letter-spacing: -0.01em;
				color: rgb(var(--black));
				display: -webkit-box;
				-webkit-line-clamp: 2;
				line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}

			.videos-empty {
				padding: 2.5em 1.5em;
				text-align: center;
				background: rgba(var(--gray-light), 0.6);
				border: 1px dashed rgb(var(--gray-light));
				border-radius: 14px;
				color: rgb(var(--gray-dark));
			}
			.videos-empty strong { display: block; font-size: 1.05em; color: rgb(var(--black)); margin-bottom: 0.3em; }
			.videos-empty a { color: var(--accent); font-weight: 600; }

			/* ========================================================
			   CLOSING CTA STRIP
			   ======================================================== */
			.closer {
				max-width: 1180px;
				margin: 2em auto 5em;
				padding: 0 1.5em;
			}
			.closer-inner {
				text-align: center;
				padding: 3em 2em;
				background:
					radial-gradient(ellipse at top right, rgba(155, 92, 255, 0.08), transparent 60%),
					radial-gradient(ellipse at bottom left, rgba(35, 55, 255, 0.08), transparent 60%),
					rgba(255, 255, 255, 0.7);
				border: 1px solid rgb(var(--gray-light));
				border-radius: 20px;
				backdrop-filter: blur(10px);
			}
			.closer h3 {
				font-size: clamp(1.5em, 3vw, 2em);
				margin: 0 0 0.4em;
				letter-spacing: -0.02em;
			}
			.closer p {
				color: rgb(var(--gray));
				margin: 0 0 1.5em;
				font-size: 1.05em;
			}

			/* ========================================================
			   SMALL SCREENS
			   ======================================================== */
			@media (max-width: 600px) {
				.hero { padding: 4em 1em 3em; }
				.featured { padding: 3em 1em 2em; }
				.closer-inner { padding: 2em 1.2em; }
			}

			/* Respect reduced motion */
			@media (prefers-reduced-motion: reduce) {
				.hero h1, .hero::before, .hero::after, .hero-inner { animation: none; }
				* { transition-duration: 0.01ms !important; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="home">
			<!-- Hero -->
			<section class="hero">
				<div class="hero-inner">
					<span class="eyebrow">✦ Hello, I'm</span>
					<h1>Shikher Goel</h1>
					<p class="tagline">Enterprise architect · AI practitioner · Writer</p>

					<div class="credentials">
						{credentials.map((c) => (
							<span class="credential">
								<svg width="12" height="12" viewBox="0 0 24 24" aria-hidden="true">
									<path fill="currentColor" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
								</svg>
								{c}
							</span>
						))}
					</div>

					<div class="cta">
						<a class="btn btn-primary" href="/writing">
							Read my writing
							<svg width="14" height="14" viewBox="0 0 24 24" aria-hidden="true">
								<path fill="currentColor" d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z"/>
							</svg>
						</a>
						<a class="btn btn-ghost" href="/about">About me</a>
					</div>
				</div>
			</section>

			<!-- Featured writing -->
			<section class="featured">
				<div class="featured-head">
					<h2>Featured writing</h2>
					<p>Recent pieces from Medium and the Forbes Tech Council.</p>
				</div>

				<div class="columns">
					<!-- Medium column -->
					<div class="column">
						<div class="column-head">
							<span class="platform-badge medium" aria-hidden="true">M</span>
							<h3>Latest on Medium</h3>
							<span class="count">{externalRaw.filter((p) => p.data.source === 'medium').length} total</span>
						</div>

						{mediumPosts.length === 0 ? (
							<p style="color: rgb(var(--gray)); font-style: italic;">Feed will populate on next build.</p>
						) : (
							mediumPosts.map((p) => (
								<a class="feature-card" href={p.data.url} target="_blank" rel="noopener noreferrer">
									<p class="card-meta">
										<FormattedDate date={p.data.pubDate} /> · Medium
									</p>
									<h4>{p.data.title}</h4>
									<p class="excerpt">{p.data.excerpt}</p>
									<svg class="card-arrow" width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
										<path fill="currentColor" d="M14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7zM19 19H5V5h7V3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2v-7h-2v7z"/>
									</svg>
								</a>
							))
						)}
					</div>

					<!-- Forbes column -->
					<div class="column">
						<div class="column-head">
							<span class="platform-badge forbes" aria-hidden="true">F</span>
							<h3>Forbes Tech Council</h3>
							<span class="count">{forbesRaw.length} total</span>
						</div>

						{forbesPosts.length === 0 ? (
							<p style="color: rgb(var(--gray)); font-style: italic;">No Forbes articles yet.</p>
						) : (
							forbesPosts.map((p) => (
								<a class="feature-card" href={p.data.url} target="_blank" rel="noopener noreferrer">
									<p class="card-meta">
										<FormattedDate date={p.data.pubDate} /> · Forbes
									</p>
									<h4>{p.data.title}</h4>
									<p class="excerpt">{p.data.excerpt}</p>
									<svg class="card-arrow" width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
										<path fill="currentColor" d="M14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7zM19 19H5V5h7V3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2v-7h-2v7z"/>
									</svg>
								</a>
							))
						)}
					</div>
				</div>

				<p class="see-all">
					<a href="/writing">
						See all {totalPosts > 0 ? totalPosts : ''} articles
						<svg width="16" height="16" viewBox="0 0 24 24" aria-hidden="true">
							<path fill="currentColor" d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z"/>
						</svg>
					</a>
				</p>
			</section>

			<!-- Latest Videos -->
			<section class="videos-section">
				<div class="videos-head">
					<h2>
						<span class="yt-dot" aria-hidden="true">
							<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
						</span>
						Latest videos
					</h2>
					{videosRaw.length > 0 && <span class="count">{videosRaw.length} videos</span>}
					<a class="channel-link" href="/videos">See all &rsaquo;</a>
				</div>

				{topVideos.length === 0 ? (
					<div class="videos-empty">
						<strong>Videos feed not yet connected.</strong>
						Add your YouTube Channel ID to <code>src/consts.ts</code> and redeploy — new uploads will appear here automatically. In the meantime, visit <a href={YOUTUBE_URL} target="_blank" rel="noopener noreferrer">the channel on YouTube</a>.
					</div>
				) : (
					<div class="video-grid">
						{topVideos.map((v) => (
							<a class="video-card" href={v.data.url} target="_blank" rel="noopener noreferrer">
								<div class="video-thumb">
									<img src={v.data.thumbnail} alt={v.data.title} loading="lazy" />
									<div class="video-play" aria-hidden="true">
										<svg width="22" height="22" viewBox="0 0 24 24" fill="white"><path d="M8 5v14l11-7z"/></svg>
									</div>
								</div>
								<div class="video-body">
									<p class="meta"><FormattedDate date={v.data.pubDate} /></p>
									<h3>{v.data.title}</h3>
								</div>
							</a>
						))}
					</div>
				)}
			</section>

			<!-- Closing CTA -->
			<section class="closer">
				<div class="closer-inner">
					<h3>Let's talk shop.</h3>
					<p>Working on something interesting at the edge of AI, enterprise architecture, or Salesforce? I'd love to hear about it.</p>
					<div class="cta">
						<a class="btn btn-primary" href="/contact">Get in touch</a>
						<a class="btn btn-ghost" href="/projects">See projects</a>
					</div>
				</div>
			</section>
		</main>
		<Footer />
		<Chatbot />
	</body>
</html>
